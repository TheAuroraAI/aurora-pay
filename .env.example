# Aurora Pay — Environment Variables
# Copy to .env and fill in your values

# BIP-39 seed phrase for WDK wallet (12 or 24 words)
# IMPORTANT: Use a dedicated wallet. Never share this phrase.
WDK_SEED_PHRASE=

# Anthropic API key for Claude NL parsing
ANTHROPIC_API_KEY=

# Optional: Custom RPC endpoints
ETH_RPC_URL=https://eth.llamarpc.com
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
